pipeline {
    agent any

    parameters {
        choice(name: 'SERVICE', choices: ['admin', 'api', 'goods', 'inventory', 'order', 'user'], description: 'Service to build')
        string(name: 'version', defaultValue: 'dev', description: 'Image version tag prefix')
        string(name: 'branch', defaultValue: 'local', description: 'Image version tag suffix')
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run Go tests before building image')
        booleanParam(name: 'PUSH_IMAGE', defaultValue: true, description: 'Push image to registry after build')
    }

    environment {
        REGISTRY = "47.99.50.241:30002"
        IMAGE_NAMESPACE = "goshop"
        GO_CACHE_DIR = ".cache/go-build"
    }

    stages {
        stage('resolve service') {
            steps {
                script {
                    def services = [
                        admin: [
                            image: 'goshop-admin',
                            cmd: './cmd/admin',
                            config: 'configs/admin/admin.yaml',
                            grpcPort: '8010',
                            httpPort: '8050',
                            tests: './cmd/admin ./app/goshop/admin/...',
                        ],
                        api: [
                            image: 'goshop-api',
                            cmd: './cmd/api',
                            config: 'configs/api/api.yaml',
                            grpcPort: '8009',
                            httpPort: '8049',
                            tests: './cmd/api ./app/goshop/api/...',
                        ],
                        goods: [
                            image: 'goshop-goods-srv',
                            cmd: './cmd/goods',
                            config: 'configs/goods/srv.yaml',
                            grpcPort: '8010',
                            httpPort: '8051',
                            tests: './cmd/goods ./app/goods/...',
                        ],
                        inventory: [
                            image: 'goshop-inventory-srv',
                            cmd: './cmd/inventory',
                            config: 'configs/inventory/srv.yaml',
                            grpcPort: '8012',
                            httpPort: '8052',
                            tests: './cmd/inventory ./app/inventory/...',
                        ],
                        order: [
                            image: 'goshop-order-srv',
                            cmd: './cmd/order',
                            config: 'configs/order/srv.yaml',
                            grpcPort: '8013',
                            httpPort: '8053',
                            tests: './cmd/order ./app/order/...',
                        ],
                        user: [
                            image: 'goshop-user-srv',
                            cmd: './cmd/user',
                            config: 'configs/user/srv.yaml',
                            grpcPort: '8014',
                            httpPort: '8054',
                            tests: './cmd/user ./app/user/...',
                        ],
                    ]
                    def cfg = services[params.SERVICE]
                    env.IMAGE_NAME = cfg.image
                    env.CMD_PATH = cfg.cmd
                    env.CONFIG_PATH = cfg.config
                    env.GRPC_PORT = cfg.grpcPort
                    env.HTTP_PORT = cfg.httpPort
                    env.TEST_PACKAGES = cfg.tests
                    env.IMAGE_TAG = "${env.REGISTRY}/${env.IMAGE_NAMESPACE}/${env.IMAGE_NAME}:${params.version}.${params.branch}"
                    env.VCS_REF = sh(script: 'git rev-parse --short=12 HEAD', returnStdout: true).trim()
                }
            }
        }
        stage('test') {
            when {
                expression { return params.RUN_TESTS }
            }
            steps {
                sh 'env GOCACHE=$GO_CACHE_DIR go test $TEST_PACKAGES'
            }
        }
        stage('docker login') {
            when {
                expression { return params.PUSH_IMAGE }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'harbor-goshop', usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASSWORD')]) {
                    sh 'echo "$HARBOR_PASSWORD" | docker login -u "$HARBOR_USER" --password-stdin http://$REGISTRY'
                }
            }
        }
        stage('docker build') {
            steps {
                sh '''
                    docker build \
                      -f build/docker/Dockerfile \
                      --pull \
                      --build-arg SERVICE_NAME=$IMAGE_NAME \
                      --build-arg CMD_PATH=$CMD_PATH \
                      --build-arg CONFIG_PATH=$CONFIG_PATH \
                      --build-arg GRPC_PORT=$GRPC_PORT \
                      --build-arg HTTP_PORT=$HTTP_PORT \
                      --build-arg VERSION=${version}.${branch} \
                      --build-arg VCS_REF=$VCS_REF \
                      -t $IMAGE_TAG .
                '''
            }
        }
        stage('docker push') {
            when {
                expression { return params.PUSH_IMAGE }
            }
            steps {
                sh 'docker push $IMAGE_TAG'
            }
        }
    }
    post {
        always {
            sh 'docker logout http://$REGISTRY || true'
        }
    }
}
