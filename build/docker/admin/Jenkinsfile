pipeline {
    agent any

    parameters {
        string(name: 'version', defaultValue: 'dev', description: 'Image version tag prefix')
        string(name: 'branch', defaultValue: 'local', description: 'Image version tag suffix')
    }

    environment {
        REGISTRY = "47.99.50.241:30002"
        IMAGE_NAMESPACE = "goshop"
        IMAGE_NAME = "goshop-admin"
        CMD_PATH = "./cmd/admin"
        CONFIG_PATH = "configs/admin/admin.yaml"
        GRPC_PORT = "8010"
        HTTP_PORT = "8050"
        TEST_PACKAGES = "./cmd/admin ./app/goshop/admin/..."
    }

    stages {
        stage('test') {
            steps {
                sh 'env GOCACHE=.cache/go-build go test $TEST_PACKAGES'
            }
        }
        stage('docker login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'harbor-goshop', usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASSWORD')]) {
                    sh 'echo "$HARBOR_PASSWORD" | docker login -u "$HARBOR_USER" --password-stdin http://$REGISTRY'
                }
            }
        }
        stage('docker build') {
            steps {
                sh '''
                    docker build \
                      -f build/docker/Dockerfile \
                      --build-arg CMD_PATH=$CMD_PATH \
                      --build-arg CONFIG_PATH=$CONFIG_PATH \
                      --build-arg GRPC_PORT=$GRPC_PORT \
                      --build-arg HTTP_PORT=$HTTP_PORT \
                      -t $REGISTRY/$IMAGE_NAMESPACE/$IMAGE_NAME:${version}.${branch} .
                '''
            }
        }
        stage('docker push') {
            steps {
                sh 'docker push $REGISTRY/$IMAGE_NAMESPACE/$IMAGE_NAME:${version}.${branch}'
            }
        }
    }
}
